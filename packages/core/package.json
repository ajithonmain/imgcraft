{
  "name": "imgcraft",
  "version": "0.1.0",
  "description": "Chainable image transform pipeline — Node + Browser WASM",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cf-wasm/photon": "^0.3.6",
    "@squoosh/lib": "^0.5.3",
    "sharp": "^0.33.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@cf-wasm/photon": "^0.3.6",
    "sharp": "^0.33.0"
  },
  "peerDependenciesMeta": {
    "@cf-wasm/photon": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@upscalerjs/esrgan-slim": "^1.0.0",
    "p-queue": "^9.3.0",
    "upscalerjs": "^1.0.0"
  }
}
